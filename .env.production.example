# Production environment variables for Vercel.
# Use the same variable names in `.env.local` for local development.

# ── Shared Firebase web client
# The current codebase has one browser Firebase client in `lib/firebase.ts`.
# Auth, viewerContent, chamberWorks, client-side Firestore reads, and client-side Storage all use these variables.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Separate orchestra web client
# No `NEXT_PUBLIC_ORCHESTRA_FIREBASE_*` variables are referenced in the current codebase.
# Chamber content currently uses the shared `NEXT_PUBLIC_FIREBASE_*` client above.

# ── Firebase Admin SDK (server-side only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── External APIs
NEXT_PUBLIC_EUROPEANA_KEY=
